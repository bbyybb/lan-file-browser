# Ensure shell scripts always use LF line endings
*.sh text eol=lf

# Ensure Windows batch files always use CRLF line endings
*.bat text eol=crlf

# Python files use LF
*.py text eol=lf

# Markdown and text files use LF
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.jpg binary
*.png binary
